# ============================================
# File-Du 配置文件
# 复制此文件为 .env 并修改以下配置
# ============================================

# 文件管理页面密码（必须修改！）
ADMIN_PASSWORD=your_strong_password_here

# Session 加密密钥（随机字符串，必须修改！）
# 生成命令：openssl rand -hex 32
SESSION_SECRET=your_random_secret_key_here_change_this

# 服务端口（默认 3000）
PORT=3000

# 运行环境（生产环境设为 production，启用 cookie secure）
# NODE_ENV=production

# 单文件最大大小（默认 8GB）
# 支持格式：8GB、500MB、1024KB、2048B，不区分大小写
MAX_FILE_SIZE=8GB

# 系统总容量配额上限（默认 50GB）
MAX_TOTAL_SIZE=50GB

# API Token（用于 curl / 脚本访问，不填则禁用 Token 认证）
# 生成随机 Token：openssl rand -hex 32
# API_TOKEN=your_secret_api_token_here

# 远程下载超时时间，毫秒（默认 2 小时）
# DOWNLOAD_TIMEOUT_MS=7200000

# 最大并发下载数（默认 10）
# MAX_CONCURRENT_DOWNLOADS=10

# 日志级别：trace/debug/info/warn/error（默认 info）
# LOG_LEVEL=info
