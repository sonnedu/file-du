# ============================================
# File-Du 配置文件
# 复制此文件为 .env 并修改以下配置
# ============================================

# 文件管理页面密码（必须修改！）
ADMIN_PASSWORD=your_strong_password_here

# Session 加密密钥（随机字符串，必须修改！）
SESSION_SECRET=your_random_secret_key_here_change_this

# 服务端口（默认 3000）
PORT=3000

# 单文件最大大小（默认 8GB）
# 支持格式：8GB、500MB、1024KB、2048B，不区分大小写
# 例：MAX_FILE_SIZE=500MB  MAX_FILE_SIZE=2GB  MAX_FILE_SIZE=1024KB
MAX_FILE_SIZE=8GB
